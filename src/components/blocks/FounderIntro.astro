---
/**
 * «Кто за этим стоит»: фото команды + короткий текст о команде из макета.
 */
const bullets = [
  "Начинаем с анализа, а не с кода",
  "Создаём документы, по которым может работать любая команда, — не привязываем вас к себе",
  "Говорим на вашем языке: с бизнесом — о пользе, с командами — про SRS и критерии приёмки",
];
---

<section class="border-t-2 border-line bg-surface">
  <div
    class="section-shell grid items-center gap-[var(--space-8)] py-[var(--space-10)] md:gap-[var(--space-10)] md:py-[var(--space-12)]"
    style="grid-template-columns:repeat(auto-fit,minmax(min(420px,100%),1fr))"
  >
    <div
      data-reveal
      class="relative flex min-h-[360px] items-center justify-center overflow-hidden rounded-2xl border-2 border-line"
    >
      <img
        src="/team.png"
        alt="Команда за рабочей сессией"
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover"
      />
    </div>

    <div
      data-reveal
      data-reveal-delay="120"
      class="flex flex-col gap-[var(--space-5)]"
    >
      <span class="text-overline text-muted">Кто за этим стоит</span>
      <h2 class="text-h2 text-ink">
        Системные аналитики с опытом в коммерческой разработке
      </h2>
      <p class="text-body-article text-muted">
        Наводим порядок и в процессах компании, и внутри системы: от приёма
        заявок в салоне до SRS для продуктовой команды.
      </p>
      <ul class="flex flex-col gap-[14px]">
        {
          bullets.map((b) => (
            <li class="flex items-start gap-[14px]">
              <span
                aria-hidden="true"
                class="mt-[7px] h-[10px] w-[10px] shrink-0 rounded-[2px] bg-accent"
              />
              <span class="text-body text-ink">{b}</span>
            </li>
          ))
        }
      </ul>
      <a
        href="/about"
        class="text-button inline-flex items-center gap-[var(--space-2)] text-accent no-underline hover:text-accent-hover"
      >
        Подробнее о нас <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
