---
import ServiceStepCard from "@/components/blocks/ServiceStepCard.astro";

/**
 * Полная лестница услуг для /services: четыре ступени развёрнуто (без
 * аккордеона), каждая — самоценна. Данные ступеней — из ядра §2 «Услуги:
 * ступени, артефакты, границы». Цена ступени «Разработка» в ядре не числом —
 * фиксируется по итогам проектирования, поэтому вместо вилки указано условие.
 */
const steps = [
  {
    n: "1 / 4",
    filled: 1,
    time: "1–2 недели",
    name: "Экспресс-диагностика",
    price: "20–30 тыс ₽",
    includes: [
      "Интервью с вами и командой",
      "Разбор процессов и текущих инструментов",
      "Карта проблем с приоритетами",
      "План: что чинить и в каком порядке",
    ],
    limits:
      "Без макетов и кода. Диагностика отвечает на вопрос «что не так и что делать», а не «как это будет выглядеть».",
    own: "Самоценна: карту проблем можно отдать любой другой команде — она не привязана к нам.",
  },
  {
    n: "2 / 4",
    filled: 2,
    time: "2–4 недели",
    name: "Проектирование решения",
    price: "60–120 тыс ₽",
    includes: [
      "SRS: требования с критериями приёмки",
      "Сценарии и схемы данных",
      "Кликабельный прототип ключевых экранов",
      "Оценка и план разработки",
    ],
    limits:
      "Без разработки. Результат — полный комплект документов и прототипов, по которому можно строить.",
    own: "Самоценна: SRS написан так, что по нему может работать любая команда — не только мы.",
  },
  {
    n: "3 / 4",
    filled: 3,
    time: "от 1,5 месяцев",
    name: "Разработка",
    price: "по итогам проектирования",
    includes: [
      "Система строго по SRS",
      "Приёмка по критериям, а не «по ощущениям»",
      "Обучение вас и команды",
      "Запуск и месяц наблюдения",
    ],
    limits:
      "Объём зафиксирован в SRS: новые «хотелки» — в бэклог следующего этапа, а не в смету текущего.",
    own: "Самоценна: рабочая система с документацией — сопровождать её сможет любой подрядчик.",
  },
  {
    n: "4 / 4",
    filled: 4,
    time: "по подписке",
    name: "Поддержка",
    price: "10–20 тыс ₽/мес",
    includes: [
      "Ведение и приоритизация бэклога",
      "Доработки по согласованному плану",
      "Документация всегда актуальна",
      "Аналитик на связи",
    ],
    limits:
      "Объём работ — по согласованному месячному плану; крупные доработки оцениваются отдельно.",
    own: "Самоценна: подписку можно остановить в любой месяц — система и документы остаются у вас.",
  },
];
---

<section class="border-t-2 border-line bg-surface">
  <div class="section-shell py-[var(--space-10)] md:py-[var(--space-11)]">
    <div
      class="grid items-stretch gap-[var(--space-5)]"
      style="grid-template-columns:repeat(auto-fit,minmax(min(290px,100%),1fr))"
    >
      {steps.map((s) => <ServiceStepCard {...s} />)}
    </div>

    <p data-reveal class="text-body-s mt-[var(--space-7)] max-w-[820px] text-muted">
      Цены — вилки: точная смета фиксируется до старта ступени и не меняется по
      ходу. Полоски сверху карточки показывают, какая часть пути пройдена к этой
      ступени.
    </p>
  </div>
</section>
