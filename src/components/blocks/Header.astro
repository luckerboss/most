---
import ThemeToggle from "@/components/blocks/ThemeToggle.jsx";
import Logo from "@/components/Logo.astro";
---

<header
  class="sticky top-0 z-50 border-b border-line bg-header-bg backdrop-blur-[8px]"
>
  <div
    class="section-shell flex h-[var(--header-height)] items-center justify-between"
  >
    <a
      href="/"
      class="flex items-center gap-2 font-heading text-xl font-bold text-ink"
    >
      <Logo size={32} />
      Мост
    </a>

    <div class="flex items-center gap-3">
      <!-- Навигация заполняется в фазе 3 -->
      <nav aria-label="Основная навигация"></nav>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
