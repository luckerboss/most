---
import ThemeToggle from "@/components/blocks/ThemeToggle.jsx";
import MobileNav from "@/components/blocks/MobileNav.jsx";
import Logo from "@/components/Logo.astro";

const navLinks = [
  { label: "Для бизнеса", href: "/business" },
  { label: "Для IT", href: "/it" },
  { label: "Услуги", href: "/services" },
  { label: "Блог", href: "/blog" },
  { label: "О нас", href: "/about" },
];


const ctaHref = "/business#form";
const ctaLabel = "Записаться на диагностику";

const { pathname } = Astro.url;

/** @param {string} href */
const isActive = (href) =>
  href === "/blog" ? pathname === "/blog" || pathname.startsWith("/blog/") : pathname === href;
---

<header
  class="sticky top-0 z-50 border-b border-line bg-header-bg backdrop-blur-[8px]"
>
  <div
    class="section-shell flex h-[var(--header-height)] items-center justify-between gap-[var(--space-6)]"
  >
    <a
      href="/"
      class="flex items-center gap-2 font-heading text-xl font-bold text-ink"
    >
      <Logo size={32} />
      Мост
    </a>

    <div class="hidden items-center gap-[2px] burger:flex">
      <nav aria-label="Основная навигация" class="flex items-center gap-[2px]">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
              class:list={[
                "whitespace-nowrap rounded-md px-3 py-2 text-[15px] leading-[20px] font-medium no-underline transition-colors duration-[var(--motion-card)]",
                isActive(link.href)
                  ? "bg-hover text-ink"
                  : "text-muted hover:bg-hover hover:text-ink",
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="flex items-center gap-3">
      <ThemeToggle client:load />
      <a
        href={ctaHref}
        class="text-button-compact hidden h-[var(--control-height-compact)] items-center whitespace-nowrap rounded-lg border-2 border-transparent bg-accent px-5 text-belyi no-underline transition-colors duration-[var(--motion-button)] hover:border-ink hover:bg-transparent hover:text-ink burger:inline-flex"
      >
        {ctaLabel}
      </a>
      <MobileNav
        client:load
        links={navLinks}
        ctaHref={ctaHref}
        ctaLabel={ctaLabel}
        pathname={pathname}
        className="burger:hidden"
      />
    </div>
  </div>
</header>
