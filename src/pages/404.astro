---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Страница не найдена — Мост">
  <section class="site-container py-10">
    <h1 class="text-3xl text-ink">Страница не найдена</h1>
    <p class="mt-5 text-muted">
      Такой страницы нет или она была перемещена.
    </p>
    <a
      href="/"
      class="mt-5 inline-block text-accent underline-offset-4 hover:text-accent-hover hover:underline"
      >Вернуться на главную</a
    >
  </section>
</BaseLayout>
