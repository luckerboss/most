---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/blocks/Hero.astro";
import SegmentFork from "@/components/blocks/SegmentFork.astro";
import ServiceLadder from "@/components/blocks/ServiceLadder.astro";
import FounderIntro from "@/components/blocks/FounderIntro.astro";
import LatestPosts from "@/components/blocks/LatestPosts.astro";
import CtaSection from "@/components/blocks/CtaSection.astro";
import { getPublishedPosts, toCardProps } from "@/lib/blog.js";

const latestPosts = (await getPublishedPosts()).slice(0, 3).map(toCardProps);
---

<BaseLayout
  title="Мост — от хаоса в процессах к работающей системе"
  description="Системный анализ, требования и разработка для малого бизнеса и продуктовых команд. Начинаем с диагностики, а не с кода."
>
  <Hero />
  <SegmentFork />
  <ServiceLadder />
  <FounderIntro />
  {latestPosts.length > 0 && <LatestPosts posts={latestPosts} />}
  <CtaSection />
</BaseLayout>
