---
import "@fontsource-variable/onest";
import "@fontsource-variable/golos-text";
import "@fontsource/jetbrains-mono";
import "@fontsource/jetbrains-mono/500.css";
import "@/styles/global.css";

import Header from "@/components/blocks/Header.astro";
import Footer from "@/components/blocks/Footer.astro";

/**
 * Базовый layout всех страниц: шрифты, токены, anti-FOUC-скрипт темы,
 * шапка и футер.
 */
const { title = "Мост", description = "" } = Astro.props;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      // Выставляем тему до первой отрисовки, чтобы не было мигания (FOUC).
      // Приоритет: сохранённый выбор из localStorage → системная тема.
      (function () {
        var theme = null;
        try {
          theme = localStorage.getItem("theme");
        } catch (e) {}
        if (theme !== "light" && theme !== "dark") {
          theme = window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    {/* Включаем reveal-состояние до отрисовки секций: только если движение
        разрешено и есть IntersectionObserver — иначе контент всегда виден. */}
    <script is:inline>
      (function () {
        try {
          if (
            !("IntersectionObserver" in window) ||
            window.matchMedia("(prefers-reduced-motion: reduce)").matches
          ) {
            return;
          }
          document.documentElement.classList.add("reveal-on");
          document.addEventListener("DOMContentLoaded", function () {
            var io = new IntersectionObserver(
              function (entries, obs) {
                entries.forEach(function (e) {
                  if (!e.isIntersecting) return;
                  var el = e.target;
                  var d =
                    parseInt(el.getAttribute("data-reveal-delay"), 10) || 0;
                  setTimeout(function () {
                    el.classList.add("is-visible");
                  }, d);
                  obs.unobserve(el);
                });
              },
              { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
            );
            document.querySelectorAll("[data-reveal]").forEach(function (el) {
              io.observe(el);
            });
          });
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body class="flex min-h-[100vh] flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
